@{
    var active = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "") + "/"
                 + (ViewContext.RouteData.Values["action"]?.ToString() ?? "");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OLAP Kho Dữ Liệu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app">
    <aside class="sidebar">
        <div class="logo">
            <i class="bi bi-boxes"></i>
            <div>
                <div class="logo-title">OLAP Dashboard</div>
                <div class="logo-sub">BTL Kho Dữ Liệu</div>
            </div>
        </div>
        <nav class="nav flex-column">
            <div class="nav-section">Phân tích ROLAP (Cuboid)</div>
            <a class="nav-link @(active.StartsWith("BanHang/") ? "active" : "")" asp-controller="BanHang" asp-action="Index">
                <i class="bi bi-cart-check"></i> Bán hàng — 70 khối
            </a>
            <a class="nav-link @(active.StartsWith("LuuKho/") ? "active" : "")" asp-controller="LuuKho" asp-action="Index">
                <i class="bi bi-boxes"></i> Lưu kho — 40 khối
            </a>

            <div class="nav-section">Kịch bản OLAP</div>
            <a class="nav-link @(active=="Scenario/DrillChart" ? "active" : "")" asp-controller="Scenario" asp-action="DrillChart">
                <i class="bi bi-bar-chart-steps"></i> 5.3.1 Drill Chart
            </a>
            <a class="nav-link @(active=="Scenario/Pivot" ? "active" : "")" asp-controller="Scenario" asp-action="Pivot">
                <i class="bi bi-grid-3x3"></i> 5.3.2 Pivot Explorer
            </a>
            <a class="nav-link @(active=="Scenario/DrillAcross" ? "active" : "")" asp-controller="Scenario" asp-action="DrillAcross">
                <i class="bi bi-diagram-3"></i> 5.3.3 Drill Across
            </a>
            <a class="nav-link @(active=="Scenario/DrillThrough" ? "active" : "")" asp-controller="Scenario" asp-action="DrillThrough">
                <i class="bi bi-search"></i> 4.1 Drill Through
            </a>

            <div class="nav-section">Phân tích MOLAP (SSAS)</div>
            <a class="nav-link @(active.StartsWith("Dashboard/") ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Slice &amp; Dice (MDX)
            </a>
            <div class="nav-section">Hệ thống</div>
            <a class="nav-link @(active.StartsWith("Diagnostics/") ? "active" : "")" asp-controller="Diagnostics" asp-action="Index">
                <i class="bi bi-tools"></i> Diagnostics
            </a>
        </nav>
        <div class="sidebar-footer">
            <small>Cube: <b>DW Quan Ly Phan Tich</b></small>
        </div>
    </aside>

    <main class="main">
        <header class="topbar">
            <h1 class="page-title">@ViewData["Title"]</h1>
            <div class="topbar-actions">
                <span class="badge bg-light text-dark">
                    <i class="bi bi-hdd-rack"></i> SSAS: LEVANDUC\SERVER_VD1
                </span>
            </div>
        </header>
        <div class="content">
            @RenderBody()
        </div>
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
